# Discord Developer Portal → General Information
DISCORD_PUBLIC_KEY=

# Discord Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=

# Discord Developer Portal → General Information → Application ID
DISCORD_APPLICATION_ID=

# Right-click your Discord server → Copy Server ID (enable Developer Mode first)
GUILD_ID=

# Right-click your Admin/Staff role in Server Settings → Copy Role ID
ADMIN_ROLE_ID=

# Right-click your Verified role in Server Settings → Copy Role ID (given when user agrees to rules)
VERIFIED_ROLE_ID=

# Right-click your Confess channel → Copy Channel ID
CONFESS_CHANNEL_ID=

# Right-click your Announcements channel → Copy Channel ID
ANNOUNCEMENTS_CHANNEL_ID=
